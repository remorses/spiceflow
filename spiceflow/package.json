{
  "name": "spiceflow",
  "version": "1.18.0-rsc.13",
  "description": "Simple API framework with RPC and type safety",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "repository": "https://github.com/remorses/spiceflow",
  "imports": {
    "#rsc-runtime": {
      "react-server": "./dist/rsc-runtime.js",
      "default": "./dist/rsc-runtime.default.js"
    },
    "#deployment-id": {
      "types": "./dist/react/deployment-id.d.ts",
      "react-server": "./dist/react/deployment-id.rsc.js",
      "default": "./dist/react/deployment-id.js"
    },
    "#handle-ssr": {
      "types": "./dist/react/handle-ssr.d.ts",
      "react-server": "./dist/react/handle-ssr.rsc.js",
      "default": "./dist/react/handle-ssr.js"
    },
    "#node-server": {
      "types": "./dist/_node-server.d.ts",
      "bun": "./dist/_node-server.js",
      "workerd": "./dist/_node-server-unsupported.js",
      "edge-light": "./dist/_node-server-unsupported.js",
      "netlify": "./dist/_node-server-unsupported.js",
      "fastly": "./dist/_node-server-unsupported.js",
      "edge-routine": "./dist/_node-server-unsupported.js",
      "azion": "./dist/_node-server-unsupported.js",
      "lagon": "./dist/_node-server-unsupported.js",
      "wasmer": "./dist/_node-server-unsupported.js",
      "arvancloud": "./dist/_node-server-unsupported.js",
      "node": "./dist/_node-server.js",
      "deno": "./dist/_node-server.js",
      "default": "./dist/_node-server-unsupported.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },

    "./cors": {
      "types": "./dist/cors.d.ts",
      "default": "./dist/cors.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "default": "./dist/mcp.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./openapi": {
      "types": "./dist/openapi.d.ts",
      "default": "./dist/openapi.js"
    },

    "./src/*": {
      "default": "./src/*.ts"
    },
    "./cloudflare-entrypoint": {
      "default": "./dist/react/entry.rsc.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "echo '<!-- DO NOT EDIT: This file is auto-generated from root README.md -->' > ./README.md && echo '' >> ./README.md && cat ../README.md >> ./README.md && rm -rf dist *.tsbuildinfo && pnpm tsc && pnpm check-entry",
    "prepublishOnly": "pnpm build",
    "typecheck": "pnpm build",
    "gen-openapi": "pnpm tsx scripts/openapi-fern.ts",
    "docs:dev": "pnpm run gen-openapi && fern docs dev",
    "docs:prod": "pnpm run gen-openapi && fern generate --docs --force",
    "fern-sdk": "pnpm run gen-openapi && fern generate --force ",
    "fern-docs": "pnpm run gen-openapi && fern generate --docs --force",
    "play-sdk:build": "pnpm vite build --config ./scripts/play-sdk.vite.ts",
    "check-entry": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=/dev/null",
    "test": "pnpm vitest",
    "prepare": "# pnpm build",
    "watch": "tsc -w"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [],
  "author": "Tommaso De Rossi, morse <beats.by.morse@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-rsc": "^0.5.21",
    "errore": "^0.14.0",
    "eventsource-parser": "^3.0.2",
    "history": "^5.3.0",
    "isbot": "^4.1.0",
    "openapi-types": "^12.1.3",
    "superjson": "^2.2.2"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "*",
    "react": "*",
    "react-dom": "*",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@types/node": "~24.0.1",
    "@types/ps-tree": "^1.1.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ai": "^5.0.14",
    "esbuild": "^0.27.4",
    "zod": "^4.3.6",
    "eventsource": "^3.0.5",
    "formdata-node": "^6.0.3",
    "js-base64": "^3.7.7",
    "js-yaml": "^4.1.0",
    "ps-tree": "^1.2.0",
    "vite": "^8.0.0"
  }
}
