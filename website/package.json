{
  "name": "spiceflow-website",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "pnpm readme && vite build",
    "readme": "cp ../README.md ./app/readme.mdx && cp ../README.md ./public/readme.md",
    "deploy:prod": "pnpm run build && wrangler deploy",
    "dev": "pnpm readme && vite dev",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "vite preview",
    "typecheck": "tsc",
    "typegen": "wrangler types",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.28.0",
    "@cloudflare/workers-types": "^4.20251003.0",
    "@code-hike/mdx": "^0.9.0",
    "@mdx-js/react": "^3.1.0",
    "@mdx-js/rollup": "^3.1.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@stefanprobst/rehype-extract-toc": "^2.2.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.0.0",
    "spiceflow": "workspace:^",
    "tailwindcss": "^4.2.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240502.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "node-fetch": "^3.3.2",
    "rehype-mdx-import-media": "^1.2.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.0",
    "wrangler": "^4.41.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
